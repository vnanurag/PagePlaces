# ─────────────────────────────────────────────────────────────────────────────
# Database (Supabase or Neon)
#
# DATABASE_URL  — pooled connection string (PgBouncer / Supabase Pooler).
#                 Used by Prisma Client at runtime. Append ?pgbouncer=true on Neon.
# DIRECT_URL    — direct (non-pooled) connection string.
#                 Used by Prisma Migrate — migrations CANNOT run through a pooler.
#
# Supabase example:
#   DATABASE_URL  = "postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres"
#   DIRECT_URL    = "postgresql://postgres.[ref]:[pw]@db.[ref].supabase.co:5432/postgres"
#
# Neon example:
#   DATABASE_URL  = "postgresql://[user]:[pw]@[host]-pooler.neon.tech/[db]?sslmode=require&pgbouncer=true"
#   DIRECT_URL    = "postgresql://[user]:[pw]@[host].neon.tech/[db]?sslmode=require"
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.vzgceozkflyyzacwphau:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.vzgceozkflyyzacwphau:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.co:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────────
# NextAuth.js v5
# Generate AUTH_SECRET with: openssl rand -base64 32
# AUTH_URL is optional locally; required on Vercel (set via env var in dashboard)
# ─────────────────────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"
AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────────
# Google Books API
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_BOOKS_API_KEY="your-google-books-api-key"
